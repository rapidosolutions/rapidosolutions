NODE_ENV=development
PORT=4174
MONGODB_URI=mongodb://127.0.0.1:27017/rapido
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
JWT_EXPIRES_IN=8h
ADMIN_EMAIL=rapidosolutionsco@outlook.com
ADMIN_PASSWORD=replace-with-a-strong-initial-password
CONTACT_RECIPIENT_EMAIL=rapidosolutionsco@outlook.com
FRONTEND_URLS=http://localhost:5173
API_PUBLIC_URL=http://localhost:4174
TRUST_PROXY=false
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Required in production for contact email delivery.
RESEND_API_KEY=
EMAIL_FROM=Rapido Solutions <website@your-verified-domain.com>

# Required in production for persistent blog cover images.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
