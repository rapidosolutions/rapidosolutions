{
  "name": "rapido-solutions-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite --config frontend/vite.config.js",
    "dev:api": "npm --prefix backend run dev",
    "dev:studio": "npm --prefix backend/sanity/studio run dev",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "vite build --config frontend/vite.config.js",
    "build:studio": "npm --prefix backend/sanity/studio run build",
    "preview": "vite preview --config frontend/vite.config.js",
    "start:api": "npm --prefix backend run start",
    "deploy:studio": "npm --prefix backend/sanity/studio run deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm run test && npm --prefix backend test && npm run build"
  },
  "dependencies": {
    "concurrently": "^10.0.3",
    "framer-motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
